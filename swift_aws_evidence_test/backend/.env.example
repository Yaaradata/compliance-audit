# ============================================================
# SWIFT AWS Evidence Test — Required .env contents
# Copy to .env and fill values. Or use parent backend/.env.
# ============================================================

# PostgreSQL (Google Cloud SQL or local)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=compliance
DB_USER=postgres
DB_PASSWORD=your_password
DB_SSL=false

# AWS (for collectors + S3)
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_DEFAULT_REGION=ap-south-1
AWS_ACCOUNT_ID=123456789012

# S3 evidence bucket (must exist in AWS)
S3_BUCKET_NAME=swift-evidence

# Schema for SWIFT evidence tables (collector_runs, evidence)
SWIFT_SCHEMA=swift_2025

# When true, Control View uses swift_2026.controls and swift_2026.evidence_sufficiency_matrix (same DB) so data is shown control-wise per SWIFT 2026 framework
USE_SWIFT_2026=false
